version: "3.9"

services:

  backend:
    build: ./backend
    container_name: local_ai_backend
    ports:
      - "8000:8000"
    volumes:
      - ./backend:/app
      - ./chroma_db:/chroma_db
    environment:
      - OLLAMA_URL=http://ollama:11434
      - NEXTCLOUD_URL=https://10.0.5.25
      - NEXTCLOUD_USER=ai_user
      - NEXTCLOUD_PASS=y7mdgwxz

  ollama:
    image: ollama/ollama
    container_name: local_ai_ollama
    ports:
      - "11434:11434"

  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    container_name: local_ai_openwebui
    ports:
      - "8081:8080"
    environment:
      - OLLAMA_BASE_URL=http://ollama:11434
      - OPENAI_API_BASE_URL=http://backend:8000/v1
      - OPENAI_API_KEY=sk-local
    depends_on:
      - backend
      - ollama
